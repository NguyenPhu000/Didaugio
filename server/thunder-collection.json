{
  "client": "Thunder Client",
  "collectionName": "Didaugio - 4 New Features Testing",
  "dateExported": "2026-01-01",
  "version": "1.2",
  "folders": [
    {
      "name": "1. Email Verification",
      "requests": [
        {
          "name": "1.1 Create Email Verification",
          "method": "POST",
          "url": "http://localhost:8081/api/email-verifications",
          "headers": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"userId\": 1,\n  \"email\": \"test@example.com\"\n}"
          },
          "tests": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(pm.response.json().data.token).to.exist);"
          ]
        },
        {
          "name": "1.2 Get Email Verifications (All)",
          "method": "GET",
          "url": "http://localhost:8081/api/email-verifications?page=1&limit=10",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ],
          "tests": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has pagination', () => pm.expect(pm.response.json().pagination).to.exist);",
            "pm.test('DESC order', () => {",
            "  const data = pm.response.json().data;",
            "  if (data.length > 1) {",
            "    pm.expect(new Date(data[0].createdAt)).to.be.above(new Date(data[1].createdAt));",
            "  }",
            "});"
          ]
        },
        {
          "name": "1.3 Get Email Verifications (Filter by userId)",
          "method": "GET",
          "url": "http://localhost:8081/api/email-verifications?userId=1&page=1&limit=10",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        },
        {
          "name": "1.4 Get Email Verifications (Filter by status=pending)",
          "method": "GET",
          "url": "http://localhost:8081/api/email-verifications?status=pending&page=1&limit=10",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        },
        {
          "name": "1.5 Verify Email (Public)",
          "method": "POST",
          "url": "http://localhost:8081/api/email-verifications/verify",
          "headers": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
          },
          "tests": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('verifiedAt exists', () => pm.expect(pm.response.json().data.verifiedAt).to.exist);"
          ]
        },
        {
          "name": "1.6 Resend Email Verification",
          "method": "POST",
          "url": "http://localhost:8081/api/email-verifications/resend/1",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ],
          "tests": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('New token created', () => pm.expect(pm.response.json().data.token).to.exist);"
          ]
        }
      ]
    },
