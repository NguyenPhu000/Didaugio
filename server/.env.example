# DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/didaugio"

# JWT & AUTHENTICATION
# JWT_SECRET must be at least 32 characters (256 bits), recommend 64+ random characters
JWT_SECRET="your-super-secret-key-min-32-chars-long-for-security"

# FIELD ENCRYPTION (AES-256-GCM for sensitive data like CCCD, bank accounts)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Replace with your own generated key! Do NOT use the example value.
FIELD_ENCRYPTION_KEY="REPLACE_WITH_YOUR_OWN_64_HEX_CHAR_KEY"
ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# SMTP EMAIL CONFIGURATION (cho gửi email xác thực)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-digit-app-password"
EMAIL_FROM="Didaugio <your-email@gmail.com>"

# FRONTEND URL
FRONTEND_URL="http://localhost:5173"

# SERVER
PORT=8081
NODE_ENV="development"

# Booking: chạy expire PENDING quá hạn định kỳ (ms). 0 = tắt. Mặc định khi không set: 300000 (5 phút).
BOOKING_PENDING_EXPIRE_INTERVAL_MS=300000

# HTTP Cache-Control cho GET danh mục / quận / phường (giây). 0 = vẫn gửi header max-age=0 qua helper — tốt nhất để 60–300.
HTTP_CACHE_STATIC_LIST_SEC=120

# ─── Groq Cloud AI Gateway ───────────────────────────────────────────────────
# Tạo API Key tại https://console.groq.com (bắt đầu bằng gsk_)
GROQ_API_KEY="gsk_nhap_api_key_groq_cua_ban_o_day"
GROQ_MODEL_NAME="meta-llama/llama-4-scout-17b-16e-instruct"

# Routing (OSRM self-host)
ROUTING_ENGINE=osrm
OSRM_URL=http://localhost:5000
ROUTING_TIMEOUT_MS=4500
ROUTE_CACHE_TTL_SEC=300
ROUTING_ENABLED=true
ROUTING_TABLE_TIMEOUT_MS=8000

# Cloudinary (Media Storage & CDN)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS Origins (comma-separated, mobile app origins)
CORS_ORIGINS=http://localhost:8083,exp://localhost:8083

# GOOGLE OAUTH 2.0 — Mobile id_token flow
# Dùng Web Client ID để backend verify audience của id_token từ mobile app
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ─── Payment Gateways ────────────────────────────────────────────────────────

# VNPay Sandbox
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_RETURN_URL=http://localhost:8081/api/payments/vnpay-return

# MoMo Sandbox — đăng ký tại https://developers.momo.vn
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:8081/api/payments/momo-return
MOMO_IPN_URL=http://localhost:8081/api/payments/momo-ipn

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BNx...
# VAPID_PRIVATE_KEY=abc...
# VAPID_SUBJECT=mailto:admin@didaugio.com

