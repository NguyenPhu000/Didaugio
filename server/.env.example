# DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/didaugio"

# JWT & AUTHENTICATION
# JWT_SECRET must be at least 32 characters (256 bits), recommend 64+ random characters
JWT_SECRET="your-super-secret-key-min-32-chars-long-for-security"

# FIELD ENCRYPTION (AES-256-GCM for sensitive data like CCCD, bank accounts)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Replace with your own generated key! Do NOT use the example value.
FIELD_ENCRYPTION_KEY="REPLACE_WITH_YOUR_OWN_64_HEX_CHAR_KEY"

# E-SIGNATURE (HMAC secret for contract signing hash)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fallback: JWT_SECRET + "_sig" nếu không set
# SIGNATURE_SECRET=""
ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES_DAYS=7
REMEMBER_ME_EXPIRES_DAYS=30
BCRYPT_ROUNDS=13

# Account lockout
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15

# SMTP EMAIL CONFIGURATION (cho gửi email xác thực)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-digit-app-password"
EMAIL_FROM="Didaugio <your-email@gmail.com>"

# FRONTEND URL
FRONTEND_URL="http://localhost:5173"

# SERVER
PORT=8081
NODE_ENV="development"
BODY_LIMIT="2mb"

# PRISMA LOG: "error,warn" (default) | "query,error,warn" (debug SQL)
PRISMA_LOG="error,warn"

# CORS
CORS_ALLOW_ALL=false

# Booking: chạy expire PENDING quá hạn định kỳ (ms). 0 = tắt. Mặc định khi không set: 300000 (5 phút).
BOOKING_PENDING_EXPIRE_INTERVAL_MS=300000

# HTTP Cache-Control cho GET danh mục / quận / phường (giây). 0 = vẫn gửi header max-age=0 qua helper — tốt nhất để 60–300.
HTTP_CACHE_STATIC_LIST_SEC=120

# ─── Groq Cloud AI Gateway ───────────────────────────────────────────────────
# Tạo API Key tại https://console.groq.com (bắt đầu bằng gsk_)
GROQ_API_KEY="gsk_nhap_api_key_groq_cua_ban_o_day"
GROQ_MODEL_NAME="meta-llama/llama-4-scout-17b-16e-instruct"
GROQ_AUDIO_GUIDE_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# AI Audio Guide TTS
# none = chỉ lưu text guide và để mobile fallback bằng expo-speech.

# Routing (OSRM self-host)
ROUTING_ENGINE=osrm
OSRM_URL=http://localhost:5000
ROUTING_TIMEOUT_MS=4500
ROUTE_CACHE_TTL_SEC=300
ROUTING_ENABLED=true
ROUTING_TABLE_TIMEOUT_MS=8000

# Cloudinary (Media Storage & CDN)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8083,exp://localhost:8083

# GOOGLE OAUTH 2.0
# Dùng Web Client ID để backend verify audience của id_token (cả mobile và web)
# Lấy từ Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# KÃª khai thÃªm náº¿u mobile preview / production dÃ¹ng client native riÃªng
# GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com

# ─── Payment Gateways ────────────────────────────────────────────────────────

# Thông tin ngân hàng nhận thanh toán (dùng tạo QR chuyển khoản trực tiếp SePay)
# bank: mã ngân hàng theo VietQR (VD: MBBank, Vietcombank, ACB...)
BANK_NAME=MBBank
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A

# (Tuỳ chọn) Cấu hình URL ảnh QR SePay — mặc định https://qr.sepay.vn/img, template=compact
# SEPAY_QR_IMAGE_BASE=https://qr.sepay.vn/img
# SEPAY_QR_TEMPLATE=compact

# Tiền tố mã thanh toán (transactionRef) — dùng để regex match nội dung CK từ webhook
PAYMENT_CODE_PREFIX=DDG

# SePay Payment Gateway — đăng ký tại https://my.sepay.vn
# (Không còn dùng cho luồng QR chuyển khoản trực tiếp, giữ lại cho tương thích)
SEPAY_ENV=
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=

# SePay Webhooks (Dashboard → Tích hợp → Webhooks → Bảo mật → HMAC-SHA256)
# Điền Secret Key từ SePay Dashboard khi tạo webhook. Để trống = bỏ qua xác thực (dev only)
SEPAY_WEBHOOK_SECRET=

# VNPay Sandbox
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_RETURN_URL=http://localhost:8081/api/payments/vnpay-return

# MoMo Sandbox — đăng ký tại https://developers.momo.vn
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:8081/api/payments/momo-return
MOMO_IPN_URL=http://localhost:8081/api/payments/momo-ipn

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BNx...
# VAPID_PRIVATE_KEY=abc...
# VAPID_SUBJECT=mailto:admin@didaugio.com

# ─── Subscription Lifecycle Schedulers ───────────────────────────────────────
# Timezone cho cron jobs (mặc định Asia/Ho_Chi_Minh)
# TZ=Asia/Ho_Chi_Minh

# Số ngày nhắc nhở trước khi hết hạn (mặc định 3)
# SUBSCRIPTION_REMINDER_DAYS=3

# Số ngày grace period (mặc định 3)
# SUBSCRIPTION_GRACE_DAYS=3

# Cron expressions (node-cron format). "off" = tắt scheduler.
# SUBSCRIPTION_RENEWAL_CRON=0 8 * * *     # 8:00 AM hàng ngày — nhắc nhở gia hạn
# SUBSCRIPTION_GRACE_CRON=0 9 * * *       # 9:00 AM hàng ngày — kiểm tra grace period
# SUBSCRIPTION_PAST_DUE_CRON=0 10 * * *   # 10:00 AM hàng ngày — kiểm tra past due
# SUBSCRIPTION_FEATURE_LOCK_CRON=0 * * * * # Mỗi giờ — cập nhật feature lock cache
# SUBSCRIPTION_STATS_CRON=0 0 * * *        # Midnight — tính MRR, churn rate

