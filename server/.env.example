# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://username:password@localhost:5432/didaugio"

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
JWT_SECRET="your-super-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# =============================================================================
# SMTP EMAIL CONFIGURATION (cho gửi email xác thực)
# =============================================================================

# --- OPTION 1: Gmail (Miễn phí, cần App Password) ---
# Hướng dẫn lấy App Password:
# 1. Vào https://myaccount.google.com/security
# 2. Bật "2-Step Verification"
# 3. Tìm "App passwords" và tạo password mới
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-digit-app-password"
EMAIL_FROM="Didaugio <your-email@gmail.com>"

# --- OPTION 2: Outlook/Hotmail (Miễn phí) ---
# SMTP_HOST="smtp-mail.outlook.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="your-email@outlook.com"
# SMTP_PASS="your-password"
# EMAIL_FROM="Didaugio <your-email@outlook.com>"

# --- OPTION 3: Custom SMTP (VD: SendGrid, Mailgun, AWS SES) ---
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASS="your-sendgrid-api-key"
# EMAIL_FROM="Didaugio <no-reply@yourdomain.com>"

# =============================================================================
# FRONTEND URL
# =============================================================================
FRONTEND_URL="http://localhost:5173"

# =============================================================================
# SERVER
# =============================================================================
PORT=3000
NODE_ENV="development"
