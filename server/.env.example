# DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/didaugio"

# JWT & AUTHENTICATION
JWT_SECRET="your-super-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# SMTP EMAIL CONFIGURATION (cho gửi email xác thực)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-digit-app-password"
EMAIL_FROM="Didaugio <your-email@gmail.com>"

# FRONTEND URL
FRONTEND_URL="http://localhost:5173"

# SERVER
PORT=3000
NODE_ENV="development"

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH 2.0 — Server-side Authorization Code Flow
# Tạo tại: https://console.cloud.google.com/apis/credentials
# Loại credential: OAuth 2.0 Client ID → Web application
#
# Authorized redirect URIs phải thêm ĐÚNG URL bên dưới:
#   • Dev (Android emulator + adb reverse): http://localhost:8081/api/auth/google/web/callback
#   • Dev (real device / ngrok):           https://<your-ngrok>.ngrok-free.app/api/auth/google/web/callback
#   • Production:                           https://api.yourdomain.com/api/auth/google/web/callback
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Phải khớp 100% với URL đã đăng ký trong Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:8081/api/auth/google/web/callback
# Deep link scheme của app (khớp với app.json → "scheme")
APP_SCHEME=didaugio
