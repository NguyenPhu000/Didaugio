{
  "version": 8,
  "name": "Đi Đâu Giờ - Cần Thơ Map",
  "sources": {
    "osm": {
      "type": "raster",
      "tiles": [
        "https://tiles.openfreemap.org/styles/positron/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenFreeMap contributors"
    },
    "cantho-districts": {
      "type": "geojson",
      "data": "http://localhost:8081/api/boundaries/districts"
    },
    "cantho-wards": {
      "type": "geojson",
      "data": "http://localhost:8081/api/boundaries/wards"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "raster",
      "source": "osm",
      "minzoom": 0,
      "maxzoom": 22
    },
    {
      "id": "districts-circle",
      "type": "circle",
      "source": "cantho-districts",
      "minzoom": 8,
      "maxzoom": 22,
      "paint": {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          8,
          12,
          20
        ],
        "circle-color": [
          "case",
          ["boolean", ["feature-state", "selected"], false],
          "#10b981",
          ["boolean", ["feature-state", "hover"], false],
          "#3b82f6",
          "#cbd5e1"
        ],
        "circle-opacity": [
          "case",
          ["boolean", ["feature-state", "selected"], false],
          0.8,
          ["boolean", ["feature-state", "hover"], false],
          0.6,
          0.4
        ],
        "circle-stroke-width": 2,
        "circle-stroke-color": "#475569"
      }
    },
    {
      "id": "districts-label",
      "type": "symbol",
      "source": "cantho-districts",
      "minzoom": 9,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-size": 14,
        "text-anchor": "top",
        "text-offset": [0, 1.5]
      },
      "paint": {
        "text-color": "#1e293b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "wards-circle",
      "type": "circle",
      "source": "cantho-wards",
      "minzoom": 12,
      "paint": {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          4,
          16,
          12
        ],
        "circle-color": [
          "case",
          ["boolean", ["feature-state", "selected"], false],
          "#10b981",
          "#e2e8f0"
        ],
        "circle-opacity": [
          "case",
          ["boolean", ["feature-state", "selected"], false],
          0.7,
          0.3
        ],
        "circle-stroke-width": 1,
        "circle-stroke-color": "#64748b"
      }
    },
    {
      "id": "wards-label",
      "type": "symbol",
      "source": "cantho-wards",
      "minzoom": 13,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-size": 11,
        "text-anchor": "top",
        "text-offset": [0, 1]
      },
      "paint": {
        "text-color": "#475569",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
