# API Server URL
# LAN IP cho thiết bị thật, 10.0.2.2 cho Android Emulator
EXPO_PUBLIC_API_URL=http://192.168.1.13:8081/api

# Google OAuth Client IDs — Google Cloud Console > Credentials
# Web: Dùng cho Expo Go dev + auth session proxy
# Android: Dùng cho standalone/production builds (cần SHA-1)
# iOS: Dùng cho standalone/production iOS builds
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
