# API Server URL
# LAN IP cho thiết bị thật, 10.0.2.2 cho Android Emulator
EXPO_PUBLIC_API_URL=http://192.168.1.13:8081/api
EXPO_PUBLIC_API_URL_PROD=https://api.yourdomain.com/api
EXPO_PUBLIC_USE_RUNTIME_HOST=false
EXPO_PUBLIC_LOCAL_API_PORT=8081
EXPO_PUBLIC_API_FALLBACK_URL=
# Required for Expo Go Google OAuth proxy redirect:
# https://auth.expo.io/@<owner>/<slug>
EXPO_PUBLIC_EXPO_OWNER=
EXPO_PUBLIC_EXPO_SLUG=

# Google OAuth Client IDs — Google Cloud Console > Credentials
# Web: BẮT BUỘC khi gọi backend /auth/google để nhận id_token
# Android: Android OAuth client (đúng package + SHA-1)
# iOS: iOS OAuth client; dùng để Expo config plugin tự tạo iosUrlScheme
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
