{
  "expo": {
    "name": "iPoint Genie",
    "slug": "iPointGenie-app",
    "scheme": "didaugio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#a7f3d0"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-asset",
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "iPoint Genie cần micro để bạn trò chuyện bằng giọng nói với Genie.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0077b8",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#a7f3d0",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "iPoint Genie cần vị trí để hiển thị địa điểm gần bạn.",
          "locationAlwaysAndWhenInUsePermission": "iPoint Genie cần vị trí chạy nền để dẫn đường và nhắc nhở di chuyển trong hành trình của bạn.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-web-browser"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#a7f3d0"
      },
      "package": "vn.ipointgenie.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#a7f3d0",
      "barStyle": "dark-content"
    },
    "ios": {
      "bundleIdentifier": "vn.ipointgenie.app",
      "supportsTablet": false,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["momo"],
        "UIBackgroundModes": [
          "location",
          "audio",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "iPoint Genie cần vị trí để hiển thị địa điểm gần bạn.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "iPoint Genie cần vị trí chạy nền để dẫn đường và nhắc nhở di chuyển trong hành trình của bạn.",
        "NSLocationAlwaysUsageDescription": "iPoint Genie cần vị trí chạy nền để dẫn đường.",
        "NSMicrophoneUsageDescription": "iPoint Genie cần micro để bạn trò chuyện bằng giọng nói với Genie.",
        "NSPhotoLibraryUsageDescription": "iPoint Genie cần truy cập thư viện ảnh để bạn tải lên ảnh đại diện và bài viết.",
        "NSCameraUsageDescription": "iPoint Genie cần truy cập máy ảnh để bạn chụp hình trực tiếp."
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd70727b-495e-4344-a2c7-364931acfcdf"
      }
    },
    "owner": "nguyenphu_000"
  }
}
