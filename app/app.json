{
  "expo": {
    "name": "Đi Đâu Giờ?",
    "slug": "didaugio-app",
    "scheme": "didaugio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0077b8",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0077b8",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Đi Đâu Giờ? cần vị trí để hiển thị địa điểm gần bạn."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0077b8"
      },
      "package": "vn.didaugio.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "vn.didaugio.app",
      "supportsTablet": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd70727b-495e-4344-a2c7-364931acfcdf"
      }
    },
    "owner": "nguyenphu_000"
  }
}
